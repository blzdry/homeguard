general {
    output_format = "i3bar"
    colors = true
    interval = 5
}

order += "volume master"
order += "battery 0"
order += "tztime local"

volume master {
        format = "Audio: %volume"
        format_muted = "Audio: muted (%volume)"
        device = "pulse"
}

battery 0 {
        format = "%status %percentage"
        status_chr = "Charging"
	status_bat = "Battery"
        status_full = "Full"
        integer_battery_capacity = true
        last_full_capacity = true
        path = "/sys/class/power_supply/BAT0/uevent"
}

tztime local {
    format = "%A, %B %d, %Y %I:%M %p "
}   
