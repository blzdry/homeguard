# Configuration file for i3wm on Gentoo Linux

#   в”“  в”“   в”“
# в”Џв”“в”ѓв”Џв”“в”Јв”“в”Џв”“в”ѓ
# в”—в”«в”—в”—в”›в”—в”›в”—в”»в”—
#  в”›        

# Set Windows Key
set $mod Mod4
set $refresh_i3status killall -SIGUSR1 i3status
floating_modifier $mod
tiling_drag modifier titlebar

# Font for i3status
font pango: IosevkaTermSS18 Semi-Bold 8

# в”Џв”“в”“в”Џв•‹в”Џв”“в”Џв•‹в”Џв”“в”Џв”“в•‹
# в”—в”»в”—в”»в”—в”—в”›в”›в”—в”—в”»в”› в”—

exec --no-startup-id feh --bg-scale $HOME/.config/i3/gray.jpg
exec --no-startup-id dex --autostart --environment i3
exec_always --no-startup-id picom -b
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork
exec --no-startup-id ~/.local/bin/xob-brightness.py | xob -t 1500

# в”“ вЂў   в”“ 
# в”Јв”“в”“в”Џв”“в”Џв”«в”Џ
# в”—в”›в”—в”›в”—в”—в”»в”›

### Programs ###

#- Terminal
bindsym $mod+Return exec xfce4-terminal

#- Firefox
bindsym $mod+w exec firefox

#- PacketTracer
bindsym $mod+Shift+e exec packettracer

#- File Manager
bindsym $mod+e exec pcmanfm

# Window Mark
bindsym $mod+m exec i3-input -F 'mark %s' -P 'Name: '
bindsym $mod+Shift+m exec i3-input -F '[con_mark="%s"] focus' -P 'Accelerate: '

# Scratchpad
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

# Reload i3wm
bindsym $mod+Shift+r restart
bindsym $mod+ctrl+r reload

# Powermenu
set $powerMenu "Menu: [l]ock [e]xit [r]eboot [p]oweroff"

mode $powerMenu {
    bindsym l exec --no-startup-id i3lock -c 000000,    mode "default"
    bindsym e exec --no-startup-id i3-msg exit,         mode "default"
    bindsym r exec --no-startup-id loginctl reboot,     mode "default"
    bindsym s exec --no-startup-id loginctl poweroff,   mode "default"

    bindsym Escape mode "default"
}

bindsym $mod+Delete mode $powerMenu

# Screenshot
bindsym Print exec --no-startup-id flameshot gui
bindsym $mod+Print exec --no-startup-id flameshot full -c

# Volume
bindsym XF86AudioRaiseVolume exec --no-startup-id amixer -D pulse sset Master 10%+ && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id amixer -D pulse sset Master 10%- && $refresh_i3status
bindsym XF86AudioMute        exec --no-startup-id amixer -D pulse sset Master toggle && $refresh_i3status

# Brightness
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set +5%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 5%-

# Kill Window
bindsym $mod+q kill

# Application Launcher
set $dmenu_cmd dmenu -i -fn 'MartianMonoNerdFont:size=9' -nb '#141c21' -nf '#93a1a1' -sb '#9fc5e8' -sf '#141c21'
bindsym $mod+d exec --no-startup-id j4-dmenu-desktop --dmenu="$dmenu_cmd"

#     в”“
# в”Џв”“в”“в”Џв”ѓв”Џв”“в”Џ
# в”› в”—в”»в”—в”— в”›

force_display_urgency_hint 2000 ms
focus_on_window_activation urgent
focus_follows_mouse no

default_border pixel 4
for_window [class=.*] border pixel 4

# Terminal
assign [class="xfce4-terminal"] 1:Terminal
assign [class="org.wezfurlong.wezterm"] 1:Terminal

# Firefox
for_window [class="firefox-esr" title="Library"] floating enable
assign [class="firefox-esr"] 2:Browser

# File Manager
assign [class="pcmanfm"] 3:Files

# Packet Tracer
assign [class="PacketTracer"] 4:Miscellaneous

# Blender
assign [class="Blender"] 4:Miscellaneous

# GTK Settings
assign [class="lxappearance"] 4:Miscellaneous

# Video Player
assign [class="mpv"] 5:Media

#       вЂў     вЂў
# в”Џв”“в”Џв”“в”“в”Џв”“в”Џв”“в”Џв”“в•‹в”“в”Џв”“в”Џв”“
# в”›в”—в”—в”»в”—в”›в”—в”—в”«в”—в”»в”—в”—в”—в”›в”›в”—
#         в”›

# change focus
bindsym $mod+j focus left
bindsym $mod+k focus down
bindsym $mod+l focus up
bindsym $mod+semicolon focus right

# alternatively, you can use the cursor keys:
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# move focused window
bindsym $mod+Shift+j move left
bindsym $mod+Shift+k move down
bindsym $mod+Shift+l move up
bindsym $mod+Shift+semicolon move right

# alternatively, you can use the cursor keys:
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# split in horizontal orientation
bindsym $mod+h split h

# split in vertical orientation
bindsym $mod+v split v

# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

# change container layout (stacked, tabbed, toggle split)
#bindsym $mod+s layout stacking
#bindsym $mod+w layout tabbed
#bindsym $mod+e layout toggle split

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# focus the parent container
bindsym $mod+a focus parent

# focus the child container
#bindsym $mod+d focus child

# Workspaces
bindsym $mod+1 workspace 1:Terminal
bindsym $mod+2 workspace 2:Browser
bindsym $mod+3 workspace 3:Files
bindsym $mod+4 workspace 4:Miscellaneous
bindsym $mod+5 workspace 5:Media

# Move program from Workspace X to Workspace Y
bindsym $mod+Shift+1 move container to workspace 1:Terminal
bindsym $mod+Shift+2 move container to workspace 2:Browser
bindsym $mod+Shift+3 move container to workspace 3:Files
bindsym $mod+Shift+4 move container to workspace 4:Miscellaneous
bindsym $mod+Shift+5 move container to workspace 5:Media


# resize window (you can also use the mouse for that)
mode "resize" {
        # These bindings trigger as soon as you enter the resize mode

        bindsym j resize shrink width 10 px or 10 ppt
        bindsym k resize grow height 10 px or 10 ppt
        bindsym l resize shrink height 10 px or 10 ppt
        bindsym semicolon resize grow width 10 px or 10 ppt

        # same bindings, but for the arrow keys
        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt

        bindsym Escape mode "default"
}

bindsym $mod+r mode "resize"

# вЂўв”Џв”“
# в”“ в”«в”Џв•‹в”Џв”“в•‹в”“в”Џв”Џ
# в”—в”—в”›в”›в”—в”—в”»в”—в”—в”»в”›

bar {
        status_command i3status | i3status-title-on-bar --color '#02FFBF' 
        colors {
	    background 	#141c21
	    statusline 	#FFFADA
	    separator 	#141c21

	    focused_workspace 	#141c21 #3d85c6 #fff2cc
	    active_workspace 	#141c21 #141c21 #93a1a1
	    inactive_workspace 	#141c21 #141c21 #93a1a1
	    urgent_workspace 	#141c21 #b08500 #93a1a1
	}
}

