# Aliases

--guide () {
    echo ""
    echo "append with double hyphen to execute an alias"
    echo ""
    echo -e "\e[32mnix-repo\e[0m = cd into snowflake"
    echo ""
    echo -e "\e[32mflake-rebuild\e[0m = rebuild configuration file"
    echo ""
    echo -e "\e[32mempty-current-gen\e[0m = garbage collector ONLY in this generation"
    echo ""
    echo -e "\e[32mempty-world-gen\e[0m = garbage collector that also cleans up older generation"
    echo ""
    echo -e "\e[32moptimise-store\e[0m = let nix do its own thing, takes a bit of time to complete"
    echo ""
    echo -e "\e[32mwrite-package\e[0m = edit system-user-packages.nix"
    echo ""
}

--nix-repo () {
    cd "$HOME/HG/snowflake/nixos/"
}

--flake-rebuild () (
    --nix-repo
    sudo nixos-rebuild switch --flake .#elderhailstorm --impure
)

--empty-current-gen () {
    sudo nix-collect-garbage
}

--empty-world-gen () {
    sudo nix-collect-garbage -d
}

--optimise-store () {
    sudo nix store optimise
}

--write-package () (
    --nix-repo
    vim system-user-packages.nix
)
